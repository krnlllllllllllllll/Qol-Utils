{
  "geode": "5.7.1",
  "version": "1.0.0",

  "gd": {
    "id": "qol.utils",
    "version": "1.0.0"
  },

  "name": "QOL Utils",
  "developer": "krnlllllllllllllll",
  "description": "Quality-of-life utilities for Geometry Dash.",
  "repository": "https://github.com/krnlllllllllllllll/Qol-Utils",
  "entry": "main.cpp",

  "dependencies": [
    {
      "id": "node.ids",
      "version": "*"
    }
  ],

  "autobuild": {
    "provider": "antiprime",
    "recommended": false
  },

  "limits": {
    "unsupported-features": true
  },

  "unrecommended-mods": [
    "auto-decorator-utils",
    "legacy-autodec",
    "old-style-decorator",
    "unsafe-decorator-pack"
  ],

  "settings": {
    "showDebugInfo": {
      "type": "bool",
      "default": false,
      "description": "Show extra debug info for QOL Utils."
    }
  },

  "enable-if": [
    {
      "type": "geode-version-at-least",
      "version": "5.7.1"
    }
  ]
}
